# Copy this file to `.env` and fill in the values.
# Le variabili sono validate all'avvio da src/lib/env.ts (Zod): valori mancanti
# o malformati bloccano il boot con un messaggio esplicito.

# --- Database (SQLite via Prisma) ---
DATABASE_URL="file:./prisma/dev.db"

# --- Auth ---
# Secret used to derive the per-session HMAC pepper. Keep this private.
# In produzione: obbligatorio, almeno 32 caratteri.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET="change-me-to-a-long-random-string"

# --- Modalità demo ---
# true  = i contatori partono dai baseline finti del seed (default in sviluppo)
# false = nessun numero inventato (default in produzione)
# DEMO_MODE="true"

# --- Fonte dati per sezione (Fase 2: ETL da fonti nazionali) ---
# "mock" (default) oppure "real" quando l'ETL alimenta la sezione.
# DATA_MODE_BILANCIO="mock"
# DATA_MODE_OPERE="mock"

# --- Rate limit distribuito (opzionale, consigliato in produzione) ---
# Se impostati, il rate-limiter usa Upstash Redis via REST; altrimenti
# ricade sullo store in memoria per-istanza.
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# --- Error tracking (opzionale) ---
# SENTRY_DSN="https://...@sentry.io/..."

# --- Server Actions dietro reverse proxy (opzionale) ---
# Lista di host ammessi separati da virgole, es. "dashboard.pistoia.it"
# SERVER_ACTIONS_ALLOWED_ORIGINS=""
