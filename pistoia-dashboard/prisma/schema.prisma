// Dashboard di Pistoia — data model.
// SQLite for local development; all content is mockup data seeded by prisma/seed.ts.
// Enums are modelled as strings because SQLite has no native enum type.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Identity & auth
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  publicName    String? // abbreviated public display, e.g. "Lorenzo C." (privacy)
  role          String   @default("CITIZEN") // CITIZEN | MODERATOR | MUNICIPAL_STAFF | ADMIN
  accountType   String   @default("CITIZEN") // CITIZEN | ASSOCIATION | BUSINESS | MUNICIPAL
  verifiedType  String? // null = not verified; else IDENTITY | RESIDENCY | ASSOCIATION | BUSINESS | MUNICIPAL_STAFF
  avatarColor   String   @default("teal") // teal | viola | amber | red | green
  bio           String?
  quartiere     String? // legacy free-text neighbourhood label (kept for back-compat)
  neighborhoodId String?
  neighborhood   Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  emailVerified Boolean  @default(false)
  geoConsent    Boolean  @default(false) // consent to share precise geolocation (§23)
  civicInterests String? // JSON array of civic-topic keys (A2 §3); null = preferences never chosen
  suspendedUntil DateTime? // temporary suspension end set by moderation (§14)
  banned        Boolean  @default(false) // permanent ban set by moderation (§14)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions            Session[]
  votes               Vote[]
  likes               PostLike[]
  follows             AssessoreFollow[]
  generalFollows      Follow[]
  posts               CommunityPost[]
  comments            PostComment[]
  notifications       Notification[]
  verifications       ProfileVerification[]
  badges              CitizenBadge[]
  organization        OrganizationProfile?
  reports             Report[]
  reportConfirmations ReportConfirmation[]
  proposals           Proposal[]
  proposalSupports    ProposalSupport[]
  moderationActions   ModerationAction[]
  notifPref           NotificationPreference?
  organizedEvents     Event[]
  operaComments       OperaComment[]
  commentReports      CommentReport[]
  answerFeedback      AnswerFeedback[]

  @@index([neighborhoodId])
}

// ---------------------------------------------------------------------------
// Community: trust layer (verified profiles, badges, organizations)
// ---------------------------------------------------------------------------

// Neighbourhoods and frazioni of the Comune di Pistoia. Territorial backbone
// for "Vicino a te", local feeds, reports and territorial polls.
model Neighborhood {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  kind  String @default("quartiere") // quartiere | frazione
  order Int    @default(0)

  users     User[]
  posts     CommunityPost[]
  reports   Report[]
  proposals Proposal[]
  polls     Poll[]
  opere     Opera[]
  events    Event[]
}

// A request to verify a profile. In this mock phase verification is granted by
// an admin/staff review queue (no SPID/CIE yet — labelled "simulata" in the UI).
model ProfileVerification {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String // IDENTITY | RESIDENCY | ASSOCIATION | BUSINESS | MUNICIPAL_STAFF
  status           String    @default("PENDING") // PENDING | APPROVED | REJECTED | EXPIRED
  organizationName String? // for ASSOCIATION / BUSINESS requests
  note             String? // citizen note (request) or reviewer note (decision)
  requestedAt      DateTime  @default(now())
  reviewedAt       DateTime?
  reviewedById     String? // user id of the reviewer (no relation: avoids ambiguity)
  expiresAt        DateTime?

  @@index([userId])
  @@index([status])
}

// A badge awarded to a user: verification badges + soft civic-reputation badges.
model CitizenBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeType String // identity | residency | municipal | association | business | moderator | first_contribution | reliable_reporter | active_citizen | useful_proposals
  label     String
  icon      String? // emoji or lucide name
  issuedAt  DateTime @default(now())

  @@unique([userId, badgeType])
  @@index([userId])
}

// Verified profile for an association or a local business.
model OrganizationProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // ASSOCIATION | BUSINESS
  name        String
  description String?
  category    String?
  websiteUrl  String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Community: segnalazioni (citizen reports) with tracked lifecycle
// ---------------------------------------------------------------------------

model Report {
  id                 String    @id @default(cuid())
  authorId           String?
  author             User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName         String
  authorInitials     String
  authorColor        String    @default("teal")
  title              String
  description        String
  category           String // buche | illuminazione | rifiuti | verde | sicurezza | rumore | trasporto | barriere | scuole | parchi | animali | decoro
  status             String    @default("ricevuta") // ricevuta | validata | presa_in_carico | in_lavorazione | risolta | chiusa | duplicata | non_di_competenza
  neighborhoodId     String?
  neighborhood       Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  location           String?
  latitude           Float?
  longitude          Float?
  imageSeed          String?
  photoData          String? // uploaded photo as a data URL (§9); falls back to imageSeed gradient
  anonymous          Boolean   @default(false) // partially-anonymous report: hide author publicly (§23)
  mergedIntoId       String? // when a moderator merges this into a canonical report (§14)
  assignedDepartment String?
  baseConfirmations  Int       @default(0) // mock baseline of "anche io" confirmations
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  resolvedAt         DateTime?

  // Urgenza con validazione del moderatore (A1 §8): null | richiesta | confermata | respinta.
  urgency            String?
  // Conferma del cittadino dopo la risoluzione (A1 §5): null | confermata | riaperta.
  resolutionFeedback   String?
  resolutionFeedbackAt DateTime?

  confirmations ReportConfirmation[]
  updates       ReportStatusHistory[]
  photos        ReportPhoto[]

  @@index([status])
  @@index([neighborhoodId])
}

// Foto per fase dell'intervento (A1 §4): "prima" dal cittadino (oltre alla
// photoData della segnalazione), "durante"/"dopo" dal Comune. photoData è una
// data URL; se assente, la UI mostra un placeholder a gradiente da imageSeed.
model ReportPhoto {
  id         String   @id @default(cuid())
  reportId   String
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  phase      String // prima | durante | dopo
  photoData  String?
  imageSeed  String?
  caption    String?
  authorName String?
  official   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([reportId])
}

// "Anche io" — a citizen confirms an existing report (dedupe + priority signal).
model ReportConfirmation {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reportId, userId])
  @@index([reportId])
}

model ReportStatusHistory {
  id         String   @id @default(cuid())
  reportId   String
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  status     String
  note       String?
  official   Boolean  @default(false) // true when written by the Comune
  authorName String?
  createdAt  DateTime @default(now())

  @@index([reportId])
}

// ---------------------------------------------------------------------------
// Community: proposte cittadine (citizen proposals) with support thresholds
// ---------------------------------------------------------------------------

model Proposal {
  id               String    @id @default(cuid())
  authorId         String?
  author           User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName       String
  authorInitials   String
  authorColor      String    @default("teal")
  title            String
  description      String
  problem          String? // "qual è il problema?" — separate step of the guided wizard (A1 §14)
  affectedGroups   String? // JSON array of impacted citizen-group keys (A2 §26)
  category         String?
  neighborhoodId   String?
  neighborhood     Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  imageSeed        String?
  status           String    @default("pubblicata") // bozza | pubblicata | in_valutazione | risposta | approvata | respinta
  baseSupports     Int       @default(0) // mock baseline of supporters
  officialReply    String?
  officialReplyAt  DateTime?

  // Valutazione sintetica del Comune (A1 §15 + A2 §10): indicativa, mai vincolante.
  estimatedImpact  String? // basso | medio | alto
  estimatedCost    String? // basso | medio | alto (mostrato come € / €€ / €€€)
  estimatedTime    String? // breve | medio | lungo
  feasibility      String? // da_valutare | fattibile | complessa
  assessedAt       DateTime? // quando il Comune ha compilato la valutazione
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  supports ProposalSupport[]

  @@index([status])
  @@index([neighborhoodId])
}

model ProposalSupport {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([proposalId, userId])
  @@index([proposalId])
}

// ---------------------------------------------------------------------------
// Community: generic follow + moderation/audit + notification preferences
// ---------------------------------------------------------------------------

// Generic "Segui" relation for neighborhoods, opere, reports, proposals, polls.
// (AssessoreFollow is kept separate for back-compat with the organigramma.)
model Follow {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String // neighborhood | opera | report | proposal | poll
  targetId   String
  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetId])
  @@index([userId])
}

// Append-only log of moderation + admin actions (also serves as a light audit trail).
model ModerationAction {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String // verify_approve | verify_reject | report_status | proposal_status | hide_post | answer | broadcast | ...
  targetType String
  targetId   String
  reason     String?
  createdAt  DateTime @default(now())

  @@index([actorId])
}

model NotificationPreference {
  id                  String  @id @default(cuid())
  userId              String  @unique
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  neighborhood        Boolean @default(true)
  followedItems       Boolean @default(true)
  polls               Boolean @default(true)
  proposals           Boolean @default(true)
  generalDiscussions  Boolean @default(false)
  urgent              Boolean @default(true)
}

// Opaque server-side session. `id` stores the SHA-256 hash (hex) of the cookie
// token — the raw token never touches the database.
model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Bilancio (budget)
// ---------------------------------------------------------------------------

model BudgetYear {
  id           String           @id @default(cuid())
  year         Int              @unique
  totalSpesa   Int // headline programmed spending (euro)
  totalEntrate Int
  avanzo       Int // surplus (euro), can be negative
  riscossione  Int // % of expected revenue collected
  impegni      Int // % of budget formally committed
  pnrr         Int // % of PNRR-funded quota progressed
  months       BudgetMonth[]
  categories   BudgetCategory[]

  // Provenienza del dato (Fase 1): valorizzati dall'ETL di Fase 2 (BDAP/SIOPE+).
  // Null = dato dimostrativo dal seed.
  sourceName   String? // es. "OpenBDAP (RGS-MEF)"
  sourceUrl    String?
  externalId   String? // chiave del record nella fonte
  lastSyncedAt DateTime?
}

model BudgetMonth {
  id           String     @id @default(cuid())
  yearId       String
  year         BudgetYear @relation(fields: [yearId], references: [id], onDelete: Cascade)
  month        Int // 1..12
  entrate      Int
  spese        Int
  investimenti Int

  @@unique([yearId, month])
}

model BudgetCategory {
  id     String     @id @default(cuid())
  yearId String
  year   BudgetYear @relation(fields: [yearId], references: [id], onDelete: Cascade)
  label  String // Istruzione, Mobilità, Sociale...
  amount Int
  color  String     @default("teal")
  order  Int        @default(0)
}

// ---------------------------------------------------------------------------
// Opere (public works)
// ---------------------------------------------------------------------------

model Opera {
  id          String        @id @default(cuid())
  name        String
  description String
  category    String // scuola | mobilita | piazza | restauro | verde | sociale
  progress    Int // 0..100
  status      String // in_corso | completata | pianificata | sospesa
  investment  Int // euro
  fundingSource String? // fonte di finanziamento, es. "PNRR M4C1" / "Bilancio comunale" (§18)
  rup         String? // Responsabile Unico del Procedimento (§18)
  location    String?
  latitude    Float? // for the interactive map (§10)
  longitude   Float?
  neighborhoodId String?
  neighborhood   Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  startedAt   DateTime?
  expectedEnd DateTime?
  featured    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updates     OperaUpdate[]
  photos      OperaPhoto[]
  faqs        OperaFaq[]
  comments    OperaComment[]

  // Provenienza del dato (Fase 1): valorizzati dall'ETL di Fase 2
  // (OpenCUP/ReGiS/ANAC). Null = dato dimostrativo dal seed.
  sourceName   String? // es. "OpenCUP"
  sourceUrl    String?
  externalId   String? // es. il CUP dell'opera
  lastSyncedAt DateTime?

  @@index([neighborhoodId])
  @@index([externalId])
}

// Before / during / after photos for a public work (§18). Stored as data URLs.
model OperaPhoto {
  id        String   @id @default(cuid())
  operaId   String
  opera     Opera    @relation(fields: [operaId], references: [id], onDelete: Cascade)
  phase     String // prima | durante | dopo
  data      String // image as a data URL
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([operaId])
}

// Frequently-asked questions curated by the Comune for a public work (§18).
model OperaFaq {
  id       String @id @default(cuid())
  operaId  String
  opera    Opera  @relation(fields: [operaId], references: [id], onDelete: Cascade)
  question String
  answer   String
  order    Int    @default(0)

  @@index([operaId])
}

// Citizen comments on a public work (§18). Soft-hideable by moderation.
model OperaComment {
  id             String   @id @default(cuid())
  operaId        String
  opera          Opera    @relation(fields: [operaId], references: [id], onDelete: Cascade)
  authorId       String?
  author         User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName     String
  authorInitials String
  authorColor    String   @default("teal")
  body           String
  hidden         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([operaId])
}

model OperaUpdate {
  id       String   @id @default(cuid())
  operaId  String
  opera    Opera    @relation(fields: [operaId], references: [id], onDelete: Cascade)
  date     DateTime @default(now())
  note     String
  progress Int

  @@index([operaId])
}

// ---------------------------------------------------------------------------
// Sondaggi (polls) & assessori
// ---------------------------------------------------------------------------

model Poll {
  id               String        @id @default(cuid())
  question         String
  description      String?
  year             Int
  category         String
  active           Boolean       @default(true)
  kind             String        @default("sondaggio") // sondaggio | consultazione | territoriale
  requiresVerified Boolean       @default(false) // official consultations: verified citizens only
  neighborhoodId   String? // territorial poll scoped to an area
  neighborhood     Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  assessoreId      String?
  assessore        Assessore?    @relation(fields: [assessoreId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  options          PollOption[]
  votes            Vote[]

  @@index([neighborhoodId])
}

model PollOption {
  id        String @id @default(cuid())
  pollId    String
  poll      Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label     String
  color     String @default("teal")
  baseVotes Int    @default(0) // mock baseline so live percentages look realistic
  order     Int    @default(0)
  votes     Vote[]

  @@index([pollId])
}

model Vote {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([pollId, userId]) // one vote per user per poll
  @@index([optionId])
}

model Assessore {
  id           String            @id @default(cuid())
  name         String
  role         String // "Sindaco", "Assessora all'Ambiente e al Verde"
  area         String // short delega label
  initials     String
  color        String            @default("teal")
  votesElected Int               @default(0)
  email        String?
  order        Int               @default(0)
  parentId     String?
  parent       Assessore?        @relation("OrgTree", fields: [parentId], references: [id])
  children     Assessore[]       @relation("OrgTree")
  polls        Poll[]
  follows      AssessoreFollow[]
}

model AssessoreFollow {
  id          String    @id @default(cuid())
  assessoreId String
  assessore   Assessore @relation(fields: [assessoreId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([assessoreId, userId])
}

// ---------------------------------------------------------------------------
// Comunità (community feed) & service reviews
// ---------------------------------------------------------------------------

model CommunityPost {
  id             String          @id @default(cuid())
  authorId       String?
  author         User?           @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName     String // display name snapshot (mock authors have no account)
  authorInitials String
  authorColor    String          @default("teal")
  kind           String          @default("discussione") // domanda | discussione | avviso | idea | info
  content        String
  imageSeed      String? // drives the decorative gradient
  category       String? // verde | mobilita | servizi | cultura
  neighborhoodId String?
  neighborhood   Neighborhood?   @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  hidden         Boolean         @default(false) // soft-hidden by moderation
  baseLikes      Int             @default(0)
  createdAt      DateTime        @default(now())
  likes          PostLike[]
  comments       PostComment[]
  answer         OfficialAnswer?

  @@index([neighborhoodId])
}

model OfficialAnswer {
  id         String        @id @default(cuid())
  postId     String        @unique
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  body       String
  verified   Boolean       @default(false) // true only when authored by a real Comune account
  authorRole String        @default("Comune di Pistoia")
  department String? // responsible office, e.g. "Ufficio Mobilità"
  authorId   String? // real admin/staff author (no relation: display only)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt @default(now())
}

model PostComment {
  id         String        @id @default(cuid())
  postId     String
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName String
  body       String
  hidden     Boolean       @default(false) // soft-hidden by moderation (§14)
  createdAt  DateTime      @default(now())

  reports CommentReport[]

  @@index([postId])
}

model PostLike {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([postId, userId])
}

model ServiceReview {
  id      String @id @default(cuid())
  service String // Anagrafe, Tributi online, SUAP...
  rating  Float // 4.6
  count   Int // number of reviews
  icon    String?
  order   Int    @default(0)
}

// ---------------------------------------------------------------------------
// Notifiche
// ---------------------------------------------------------------------------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // answer | poll | opera | system | event | report | proposal
  title     String
  body      String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Eventi (events calendar) — §17
// ---------------------------------------------------------------------------

// Local events: published by the Comune, or proposed by verified associations
// and approved by the Comune/moderators before becoming public.
model Event {
  id             String        @id @default(cuid())
  title          String
  description    String
  category       String // comune | associazione | mercato | mostra | teatro | sport | incontro | consiglio | assemblea | ecologica | volontariato
  startAt        DateTime
  endAt          DateTime?
  location       String?
  latitude       Float? // for the interactive map (§10)
  longitude      Float?
  neighborhoodId String?
  neighborhood   Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  organizerId    String? // null for Comune-authored events
  organizer      User?         @relation(fields: [organizerId], references: [id], onDelete: SetNull)
  organizerName  String // display name snapshot (e.g. "Comune di Pistoia", association name)
  status         String        @default("published") // proposed | published | rejected
  imageSeed      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([startAt])
  @@index([neighborhoodId])
}

// ---------------------------------------------------------------------------
// Moderation extras (§14) & "was this answer useful?" (§8)
// ---------------------------------------------------------------------------

// Per-user helpfulness vote on an official Comune answer (§8). The answer can be
// a community-post OfficialAnswer, a proposal officialReply or a report timeline.
model AnswerFeedback {
  id         String   @id @default(cuid())
  targetType String // post_answer | proposal | report
  targetId   String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  helpful    Boolean
  createdAt  DateTime @default(now())

  @@unique([targetType, targetId, userId])
  @@index([targetType, targetId])
}

// A citizen flags a community comment for moderator review (§14).
model CommentReport {
  id         String      @id @default(cuid())
  commentId  String
  comment    PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User        @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason     String? // optional free-text or category
  status     String      @default("open") // open | reviewed | dismissed
  createdAt  DateTime    @default(now())

  @@unique([commentId, reporterId])
  @@index([status])
}

// Blocked words filter for community content (§14). Admin-managed.
model BlockedWord {
  id          String   @id @default(cuid())
  word        String   @unique // stored lowercased
  createdById String? // reviewer id (display only, no relation)
  createdAt   DateTime @default(now())
}
